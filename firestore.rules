// ============================================================
//  Firestore セキュリティルール（Brevo Trigger Email対応版）
//  Firebase Console → Firestore → ルール に貼り付ける
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ユーザードキュメント ──────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
      allow create: if request.auth.uid == uid
                    && request.resource.data.keys().hasAll(['email','createdAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 200;
      allow update: if request.auth.uid == uid
                    && !('createdAt' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('uid' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── ウィッシュリスト ─────────────────────────────────
    match /users/{uid}/wishlist/{productId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // ── メールテンプレート（読み取り専用） ───────────────
    // account.html / brevo-mail.js からテンプレートを取得するため
    match /email_templates/{templateId} {
      allow read:  if request.auth != null; // ログイン済みユーザーのみ読み取り可
      allow write: if false;                // 書き込みはConsoleのみ
    }

    // ── メール送信キュー（Trigger Email Extension用） ────
    // 認証ユーザーが自分宛のメールのみ書き込み可
    match /mail/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.to == request.auth.token.email;
      allow read, update, delete: if false; // Extensionのみが処理
    }

    // ── 注文履歴（将来用） ───────────────────────────────
    match /orders/{orderId} {
      allow read:  if request.auth != null
                   && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // その他は全てアクセス拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
